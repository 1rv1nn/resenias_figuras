---
import '../styles/global.css';

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Marvel Legends Blog</title>
  </head>
  <body class="bg-white text-black min-h-screen">

    <nav class="bg-white border-b border-red-200 px-6 py-4">
      <div class="max-w-5xl mx-auto flex justify-between items-center">
        <a href="/" class="text-red-500 font-bold text-xl tracking-wide">
         Marvel Legends Blog
        </a>
        <div class="flex gap-6 text-sm text-black/70">
          <a href="./" class="hover:text-red-400 transition">Inicio</a>
          <a href="/resenas" class="hover:text-red-400 transition">Reseñas</a>
          <a href="/acerca" class="hover:text-red-400 transition">Acerca</a>
        </div>
      </div>
    </nav>

    <main class="max-w-5xl mx-auto px-6 py-10">
      <slot />
    </main>

    <footer class="text-center text-black/60 text-sm py-6 border-t border-red-100">
      © 2025 Marvel Legends Blog — Hecho con Astro
    </footer>

  </body>
</html>