---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Inicio">

  <section class="text-center py-16">
    <h1 class="text-5xl font-bold text-red-500 mb-4">Marvel Legends Blog</h1>
    <p class="text-gray-400 text-lg max-w-xl mx-auto">
      Reseñas detalladas de figuras coleccionables. Articulación, pintura, accesorios y más.
    </p>
    <a href="/resenias_figuras/resenas" class="inline-block mt-8 bg-red-600 hover:bg-red-700 text-white font-semibold px-6 py-3 rounded-lg transition">
      Ver reseñas
    </a>
  </section>

  <section>
    <h2 class="text-2xl font-bold text-white mb-6 border-b border-gray-800 pb-2">
      Últimas reseñas
    </h2>
    <p class="text-gray-500">Próximamente las primeras reseñas...</p>
  </section>

</Layout>