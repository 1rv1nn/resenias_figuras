---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const resenas = await getCollection('resenas');
console.log(resenas.map(r => r.id));
console.log('paths:', resenas.map(r => r.id.replace('.md', '')));
---

<Layout title="Reseñas">

  <h1 class="text-4xl font-bold text-red-500 mb-2">Reseñas</h1>
  <p class="text-gray-400 mb-10">Todas las figuras analizadas al detalle.</p>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    {resenas.map((resena) => (
      <a href={`${import.meta.env.BASE_URL}/resenas/${resena.id}`} class="bg-gray-900 border border-gray-800 hover:border-red-600 rounded-xl p-6 transition group">
        <div class="flex justify-between items-start mb-3">
          <span class="text-xs text-black-500 uppercase tracking-wider">{resena.data.serie}</span>
          <span class="text-yellow-400 font-bold text-lg">{resena.data.puntuacion}/10</span>
        </div>
        <h2 class="text-xl font-bold text-white group-hover:text-red-400 transition mb-2">
          {resena.data.figura}
        </h2>
        <p class="text-gray-400 text-sm">{resena.data.descripcion}</p>
        <p class="text-red-500 text-sm mt-4 font-medium">Leer reseña →</p>
      </a>
    ))}
  </div>

</Layout>